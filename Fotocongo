<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FotoCongo – Trouvez votre photographe</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- FIREBASE SDK - VERSION CORRIGÉE -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, onAuthStateChanged, signOut }
    from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
  import { getFirestore, collection, addDoc, getDocs, doc, setDoc, query, where, serverTimestamp }
    from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  // ✅ CONFIG FIREBASE FOTOCONGO
  const firebaseConfig = {
    apiKey: "AIzaSyDLg5WiF2GuWGwoHeFdFEsoX5CKaIwtcLA",
    authDomain: "fotocongo-29b79.firebaseapp.com",
    projectId: "fotocongo-29b79",
    storageBucket: "fotocongo-29b79.firebasestorage.app",
    messagingSenderId: "388529080436",
    appId: "1:388529080436:web:53a5bb9d64358e5a4fa921",
    measurementId: "G-M8F4CX1M6G"
  };

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);

  // ---- INSCRIPTION ----
  window.inscrire = async (email, pwd, nom, ville, role) => {
    try {
      const cred = await createUserWithEmailAndPassword(auth, email, pwd);
      await setDoc(doc(db, "utilisateurs", cred.user.uid), {
        nom, ville, role, email,
        abonnementActif: false,
        abonnementExpire: null,
        createdAt: serverTimestamp()
      });
      showToast("🎉 Bienvenue sur FotoCongo, " + nom + " !");
      closeModal();
      chargerPhotographes();
    } catch(e) {
      const msgs = {
        'auth/email-already-in-use': '❌ Cet email est déjà utilisé',
        'auth/weak-password': '❌ Mot de passe trop court (6 caractères min)',
        'auth/invalid-email': '❌ Email invalide'
      };
      showToast(msgs[e.code] || '❌ Erreur : ' + e.message);
    }
  };

  // ---- CONNEXION ----
  window.connecter = async (email, pwd) => {
    try {
      await signInWithEmailAndPassword(auth, email, pwd);
      showToast("✅ Connecté !");
      closeModal();
    } catch(e) {
      showToast("❌ Email ou mot de passe incorrect");
    }
  };

  // ---- DÉCONNEXION ----
  window.deconnecter = async () => {
    await signOut(auth);
    showToast("👋 À bientôt !");
  };

  // ---- ÉTAT CONNEXION ----
  onAuthStateChanged(auth, u => {
    updateNavbar(u);
    chargerPhotographes();
  });

  // ---- CHARGER PHOTOGRAPHES ----
  window.chargerPhotographes = async () => {
    const grid = document.getElementById('photogs-grid');
    if (!grid) return;
    try {
      const snap = await getDocs(query(collection(db, "utilisateurs"), where("role", "==", "photographe")));
      if (snap.empty) { grid.innerHTML = getDemodCards(); return; }
      let html = '';
      snap.forEach(d => html += makeCard(d.id, d.data()));
      grid.innerHTML = html;
    } catch { grid.innerHTML = getDemodCards(); }
  };

  // ---- ABONNEMENT PHOTOGRAPHE (2000 FCFA → toi) ----
  // Le photographe paie son abonnement directement sur ton MoMo FotoCongo Services
  // Après paiement manuel, tu actives son compte depuis l'admin
  window.demanderAbonnement = async () => {
    const user = auth.currentUser;
    if (!user) { showToast("⚠️ Connectez-vous d'abord"); openModal('login'); return; }
    // Enregistrer la demande dans Firestore
    await addDoc(collection(db, "demandes_abonnement"), {
      userId: user.uid,
      email: user.email,
      montant: 2000,
      statut: 'en_attente',
      createdAt: serverTimestamp()
    });
    showToast("✅ Demande envoyée ! Envoyez 2 000 FCFA au +242 XX XXX XXX (MTN FotoCongo Services) puis attendez l'activation.");
    // Afficher les instructions de paiement
    document.getElementById('paiement-instructions').style.display = 'block';
  };

  // ---- MISE EN RELATION CLIENT ↔ PHOTOGRAPHE (DIRECT, sans toi) ----
  // Le client contacte le photographe directement, paie directement
  // Tu ne touches pas à ce paiement — tu gagnes seulement l'abonnement
  window.contacterPhotographe = async (photoId, nomPhoto, telPhoto) => {
    const user = auth.currentUser;
    if (!user) { showToast("⚠️ Connectez-vous pour contacter ce photographe"); openModal('login'); return; }
    // Enregistrer la mise en relation
    await addDoc(collection(db, "mises_en_relation"), {
      clientId: user.uid,
      clientEmail: user.email,
      photographeId: photoId,
      photographeNom: nomPhoto,
      statut: 'initié',
      createdAt: serverTimestamp()
    }).catch(() => {});
    showToast(`📱 Contact de ${nomPhoto} : ${telPhoto || 'numéro visible sur son profil'}`);
    // Afficher le numéro du photographe (qu'il a renseigné)
    document.getElementById('contact-modal-name').textContent = nomPhoto;
    document.getElementById('contact-modal-tel').textContent = telPhoto || 'Connectez-vous pour voir le numéro';
    document.getElementById('contact-modal').style.display = 'flex';
  };

  // ---- NAVBAR ----
  window.updateNavbar = u => {
    const el = document.getElementById('nav-btns');
    if (!el) return;
    el.innerHTML = u
      ? `<span class="nav-user">👤 ${u.email.split('@')[0]}</span>
         <button class="btn-ghost-sm" onclick="deconnecter()">Déconnexion</button>`
      : `<button class="btn-ghost-sm" onclick="openModal('login')">Connexion</button>
         <button class="btn-cta-sm" onclick="openModal('signup')">S'inscrire</button>`;
  };

  window._auth = auth;
  window._db = db;
  window.serverTimestamp = serverTimestamp;
  window.addDoc = addDoc;
  window.collection = collection;
</script>

<style>
/* ═══════════════════════════════════════════
   VARIABLES DE THÈMES
═══════════════════════════════════════════ */
